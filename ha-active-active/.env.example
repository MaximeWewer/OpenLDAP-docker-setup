# Active-active (N-way Multi-Master). All nodes accept writes.

# Server identity (1, 2, 3...). Must be unique per node.
SERVER_ID=1

# Comma-separated list of peer LDAP URIs (include self). Order = serverID order.
NODE_URIS=ldap://192.168.58.10:389,ldap://192.168.58.11:389,ldap://192.168.58.12:389

# Replicator account credentials (used by syncrepl between peers)
REPLICATOR_DN=cn=replicator,ou=service-accounts,dc=example,dc=org
REPLICATOR_PASSWORD=replicatorpassword

# HAProxy stats UI auth
HAPROXY_STATS_USER=admin
HAPROXY_STATS_PASSWORD=admin

# Expose phpLDAPadmin on this node (true/false). Typically only node 1.
ENABLE_PHPLDAPADMIN=false
