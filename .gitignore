.vagrant/

# Persistent OpenLDAP data (per-mode)
docker/standalone/data/
docker/ha-active-active/data/
docker/ha-active-passive/data/

# Per-mode env + rendered HAProxy config
docker/ha-active-active/.env
docker/ha-active-passive/.env
docker/ha-active-active/haproxy/haproxy.cfg
docker/ha-active-passive/haproxy/haproxy.cfg

# TLS material (generated locally per mode)
docker/*/certs/*.crt
docker/*/certs/*.key
docker/*/certs/*.csr
docker/*/certs/*.srl

# Backup dumps (generated per mode)
docker/*/backup/*.tar.gz
docker/*/backup/*.tgz
