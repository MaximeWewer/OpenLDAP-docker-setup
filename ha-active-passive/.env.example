# Active-passive (MirrorMode + read-only consumers).
# SERVER_ID 1+2 are masters (HAProxy: 1 active, 2 backup). SERVER_ID >=3 are read-only consumers.

SERVER_ID=1
NODE_URIS=ldap://192.168.56.10:389,ldap://192.168.56.11:389,ldap://192.168.56.12:389

REPLICATOR_DN=cn=replicator,ou=service-accounts,dc=example,dc=org
REPLICATOR_PASSWORD=replicatorpassword

HAPROXY_STATS_USER=admin
HAPROXY_STATS_PASSWORD=admin

ENABLE_PHPLDAPADMIN=false
