# -*- mode: ruby -*-
# vi: set ft=ruby :
#
# OpenLDAP HA — Active-Passive (MirrorMode + 1 read-only consumer) — 3 VMs
#
#   vagrant up                  # boot cluster
#   vagrant ssh ldap1           # shell into active master
#   vagrant destroy -f          # tear down

BOX           = ENV.fetch("VAGRANT_BOX", "cloud-image/ubuntu-26.04")
NUM_NODES     = 3
SUBNET_PREFIX = "192.168.58"
BASE_OCTET    = 10
MEMORY        = 1024
CPUS          = 1

NODE_URIS = (0...NUM_NODES).map { |i| "ldap://#{SUBNET_PREFIX}.#{BASE_OCTET + i}:389" }.join(",")

unless File.respond_to?(:exists?)
  class << File
    alias_method :exists?, :exist?
  end
end

Vagrant.configure("2") do |config|
  config.vm.box = BOX

  if Vagrant.has_plugin?("vagrant-vbguest")
    config.vbguest.auto_update = false
    config.vbguest.no_install  = true
  end
  config.vm.synced_folder "../..", "/vagrant", type: "rsync",
    rsync__exclude: [".git/", ".vagrant/",
                     "standalone/data/",
                     "ha-active-active/data/", "ha-active-passive/data/",
                     "data/"]

  (1..NUM_NODES).each do |i|
    config.vm.define "ldap#{i}" do |node|
      ip = "#{SUBNET_PREFIX}.#{BASE_OCTET + i - 1}"
      node.vm.hostname = "ldap#{i}"
      node.vm.network "private_network", ip: ip

      node.vm.provider "virtualbox" do |vb|
        vb.name   = "openldap-ap-ldap#{i}"
        vb.memory = MEMORY
        vb.cpus   = CPUS
      end

      node.vm.provision "shell", path: "provision.sh", env: {
        "SERVER_ID"           => i.to_s,
        "NODE_URIS"           => NODE_URIS,
        "ENABLE_PHPLDAPADMIN" => (i == 1 ? "true" : "false")
      }
    end
  end
end
